# Chat Service 配置

# 应用配置
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8004

# 数据库配置 - 使用独立的 chat schema
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=knowledgebot
POSTGRES_PASSWORD=knowledgebot123
POSTGRES_DB=knowledgebot
POSTGRES_SCHEMA=chat

# Embedding Service 配置
EMBEDDING_SERVICE_URL=http://embedding:8003

# LLM 配置 - 选择一个提供商
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# OpenAI API (如果使用 OpenAI)
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# 通义千问 API (如果使用 Qwen)
# QWEN_API_KEY=sk-xxx
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 智谱 API (如果使用 Zhipu)
# ZHIPU_API_KEY=xxx

# SiliconFlow API (如果使用 SiliconFlow)
# SILICONFLOW_API_KEY=sk-xxx
# SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# RAG 配置
DEFAULT_TOP_K=5
DEFAULT_SCORE_THRESHOLD=0.5
MAX_HISTORY_MESSAGES=10
