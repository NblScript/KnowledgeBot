# Ingest Service 环境变量示例

# 服务配置
APP_ENV=development
APP_DEBUG=true
APP_PORT=8005

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=1

# MinIO 配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=knowledgebot
MINIO_SECURE=false

# 文档处理配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,docx,md,txt,html

# Knowledge Service
KNOWLEDGE_SERVICE_URL=http://localhost:8002

# Embedding Service
EMBEDDING_SERVICE_URL=http://localhost:8003
EMBEDDING_BATCH_SIZE=100

# HTTP 客户端配置
HTTP_TIMEOUT=30

# 日志级别
LOG_LEVEL=INFO