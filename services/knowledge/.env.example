# Knowledge Service 环境配置示例

# 应用配置
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8002

# 数据库配置 - PostgreSQL with schema
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=knowledgebot
POSTGRES_PASSWORD=knowledgebot123
POSTGRES_DB=knowledgebot
POSTGRES_SCHEMA=knowledgebot_knowledge

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530

# MinIO 配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=knowledgebot
MINIO_SECURE=false

# Embedding 配置
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# 文档处理配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,docx,md,txt,html