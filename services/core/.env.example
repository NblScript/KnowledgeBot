# ===========================================
# 应用配置
# ===========================================
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=your-secret-key-change-in-production

# ===========================================
# 数据库配置 (PostgreSQL)
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=knowledgebot
POSTGRES_PASSWORD=knowledgebot123
POSTGRES_DB=knowledgebot

# ===========================================
# Redis 配置
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===========================================
# Milvus 向量数据库配置
# ===========================================
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ===========================================
# MinIO 对象存储配置
# ===========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=knowledgebot
MINIO_SECURE=false

# ===========================================
# Embedding 配置
# ===========================================
# SiliconFlow BGE-M3 (推荐)
EMBEDDING_PROVIDER=siliconflow
SILICONFLOW_API_KEY=your-siliconflow-api-key
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# 备选: OpenAI Embedding
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536

# ===========================================
# LLM 配置
# ===========================================
# 智谱 GLM-4 (推荐)
LLM_PROVIDER=zhipu
ZHIPU_API_KEY=your-zhipu-api-key
LLM_MODEL=glm-4

# 备选: 通义千问
# LLM_PROVIDER=qwen
# QWEN_API_KEY=your-qwen-api-key
# LLM_MODEL=qwen2.5-turbo

# 备选: OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-openai-api-key
# LLM_MODEL=gpt-4o-mini

# ===========================================
# Celery 配置
# ===========================================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ===========================================
# 文档处理配置
# ===========================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,docx,md,txt,html

# ===========================================
# 检索配置
# ===========================================
DEFAULT_TOP_K=5
DEFAULT_SCORE_THRESHOLD=0.5
