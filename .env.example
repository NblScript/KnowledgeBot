# KnowledgeBot 环境配置
# 复制此文件为 .env 并填写实际值

# ==================== 应用配置 ====================
APP_ENV=development
APP_DEBUG=true

# ==================== JWT 配置 ====================
# 生产环境请更换为强密钥
JWT_SECRET_KEY=your-super-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ==================== LLM 配置 ====================
# 提供商: openai, qwen, zhipu, siliconflow, mock
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2048

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# 通义千问 (Qwen)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 智谱 AI (Zhipu)
ZHIPU_API_KEY=

# SiliconFlow
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ==================== Embedding 配置 ====================
# 提供商: openai, qwen, siliconflow, local, mock
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ==================== 数据库配置 ====================
# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=knowledgebot
POSTGRES_PASSWORD=knowledgebot123
POSTGRES_DB=knowledgebot

# ==================== Redis 配置 ====================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== Milvus 配置 ====================
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ==================== MinIO 配置 ====================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=documents
MINIO_SECURE=false

# ==================== 文档处理配置 ====================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,docx,md,txt,html

# ==================== 检索配置 ====================
DEFAULT_TOP_K=5
DEFAULT_SCORE_THRESHOLD=0.5